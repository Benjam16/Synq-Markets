{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/drawdown-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/midnight-reset",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/refresh-prices",
      "schedule": "*/2 * * * *"
    }
  ]
}
